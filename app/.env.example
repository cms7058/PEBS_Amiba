# =====================================================================
# Amoeba Copilot · environment template
# Copy to `.env` next to docker-compose.yml and fill in.
# =====================================================================

# ----------- REQUIRED in production -----------

# A long random string used to sign session JWTs.
# Generate with:   openssl rand -base64 48
AMIBA_AUTH_SECRET=

# ----------- Optional (with sensible defaults) -----------

# Seeds the initial admin user the FIRST time data/users.json is created.
# Has no effect after that file exists.
AMIBA_ADMIN_PASSWORD=admin123

# Where on the host (port) to publish the container's port 3000.
# Keep 3000 unless something else needs the port.
HOST_PORT=3000

# Public URL the mobile QR code on the home page will encode. Because this
# is a NEXT_PUBLIC_* variable it is BAKED INTO THE CLIENT BUNDLE AT BUILD TIME.
# Leaving it empty makes the QR fall back to the current browser origin + /m,
# which is fine for direct ip-port access but wrong behind a reverse proxy.
# Examples:
#   NEXT_PUBLIC_PUBLIC_URL=https://copilot.your-domain.com
NEXT_PUBLIC_PUBLIC_URL=

# Where the JSON store lives INSIDE the container. The default matches the
# docker-compose volume mount; only change if you also change the volume.
# AMIBA_DATA_DIR=/app/data

# PEBS cloud function product key for invite-code login. Default matches the
# Amoeba Copilot product registered in PEBS backend. Only override if PEBS
# re-keys the product or you want to point at a different product record.
# AMIBA_PRODUCT_KEY=product_1779676634595

# PEBS cloud function endpoint. Default works for production. Override for
# staging / private mirror.
# PEBS_CLOUD_API=https://fc-mp-ad17509f-ebae-4693-974b-769771dd93c5.next.bspapp.com/pebs-copilot-api
