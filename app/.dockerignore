# =====================================================================
# Build context exclusions — keep the image small and free of secrets.
# =====================================================================

# Dependencies & build artifacts (will be re-generated in the image)
node_modules
.next
.turbo
.cache

# VCS & editor
.git
.gitignore
.vscode
.idea
.DS_Store

# Local secrets / runtime data (never bake into the image)
.env
.env.*
!.env.example
data
*.local

# Docker meta (avoid copying into the image)
Dockerfile
.dockerignore
docker-compose*.yml

# Docs & logs
README*.md
DEPLOY*.md
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Test coverage / outputs
coverage
out
dist
